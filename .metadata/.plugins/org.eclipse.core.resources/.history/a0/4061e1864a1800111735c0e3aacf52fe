#define STM32F446xx
#include "stm32f4xx.h"
#include <stdint.h>

void delay_ms(uint32_t ms) {
    // Adding 'volatile' ensures the compiler doesn't skip this loop
    for (volatile uint32_t i = 0; i < ms * 4000; i++) {
        __NOP();
    }
}

int main(void) {
    /* 1. Enable GPIOA clock */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOAEN;

    /* 2. Brief delay to allow clock to stabilize */
    __DSB();

    /* 3. Configure PA5 as Output */
    GPIOA->MODER &= ~(3UL << (5 * 2)); // Clear bits
    GPIOA->MODER |= (1UL << (5 * 2));  // Set as Output (01)

    while (1) {
        /* Toggle PA5 using BSRR */
        GPIOA->BSRR = (1UL << 5);         // ON
        delay_ms(500);
        GPIOA->BSRR = (1UL << (5 + 16));  // OFF
        delay_ms(500);
    }
} // <--- Added missing brace
