#define STM32F446xx           /* ১. আপনার চিপের মডেলটি এখানে ডিফাইন করা হয়েছে */
#include "stm32f4xx.h"
#include <stdint.h>           /* ২. uint32_t চিনতে এটি প্রয়োজন */

void delay_ms(uint32_t ms) {
    /* Software delay : ~16 MHz HSI -> ~4,000 NOP iterations per ms */
    for (uint32_t i = 0; i < ms * 4000; i++) {
        __NOP();              /* ৩. এখন কম্পাইলার এটি চিনবে */
    }
}

int main(void) {
    /* 1. Enable GPIOA clock on AHB1 bus */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOAEN;
    __NOP(); __NOP();         /* brief settle delay */

    /* 2. MODER: set PA5 as General Purpose Output */
    GPIOA->MODER &= ~(3UL << (5 * 2));
    GPIOA->MODER |= (1UL << (5 * 2));

    /* 3. OTYPER: Push-Pull */
    GPIOA->OTYPER &= ~(1UL << 5);

    /* 4. OSPEEDR: Low speed */
    GPIOA->OSPEEDR &= ~(3UL << (5 * 2));

    /* 5. PUPDR: No pull */
    GPIOA->PUPDR &= ~(3UL << (5 * 2));

    while (1) {
        /* 6. Toggle LED using BSRR register */
        GPIOA->BSRR = (1UL << 5);         /* Set PA5 -> LED ON */
        delay_ms(500);
        GPIOA->BSRR = (1UL << (5 + 16));  /* Reset PA5 -> LED OFF */
        delay_ms(500);
    }
}

