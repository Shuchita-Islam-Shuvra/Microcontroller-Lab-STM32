#define STM32F446xx
#include "stm32f4xx.h"
#include <stdint.h>
#include <stdio.h>

#define BUF_SIZE 128
volatile char ring[BUF_SIZE];
volatile uint8_t head = 0, tail = 0;
volatile uint8_t lineReady = 0;

/* USART2 ISR */
void USART2_IRQHandler(void) {
    if (USART2->SR & USART_SR_RXNE) {
        char c = (char)USART2->DR;
        ring[head] = c;
        head = (head + 1) % BUF_SIZE;
        if (c == '\r' || c == '\n') lineReady = 1;
    }
    if (USART2->SR & USART_SR_ORE) {
        (void)USART2->DR;
    }
}

/* Send string via USART2 */
void USART2_SendString(const char *s) {
    while (*s) {
        while (!(USART2->SR & USART_SR_TXE));
        USART2->DR = (uint8_t)(*s++);
    }
}

int main(void) {
    /* GPIOA + USART2 clock and AF config */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOAEN;
    RCC->APB1ENR |= RCC_APB1ENR_USART2EN;
    __NOP(); __NOP();

    /* PA2=TX, PA3=RX */
    GPIOA->MODER &= ~((3UL << 4) | (3UL << 6));
    GPIOA->MODER |= ((2UL << 4) | (2UL << 6));
    GPIOA->AFR[0] &= ~((0xFUL << 8) | (0xFUL << 12));
    GPIOA->AFR[0] |= ((7UL << 8) | (7UL << 12));

    /* USART2 setup */
    USART2->BRR = (390 << 4) | 10; /* 115200 @ 45 MHz */
    USART2->CR1 = USART_CR1_UE | USART_CR1_TE | USART_CR1_RE | USART_CR1_RXNEIE;
    NVIC_SetPriority(USART2_IRQn, 1);
    NVIC_EnableIRQ(USART2_IRQn);

    /* Enable GPIOC clock for button */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOCEN;
    /* PC13 input (button) */
    GPIOC->MODER &= ~(3UL << 26);

    USART2_SendString("UART + Button Demo: type or press B2\r\n");

    while (1) {
        /* Check button state (active low) */
        if (!(GPIOC->IDR & (1UL << 13))) {
            USART2_SendString("B2 Pressed!\r\n");
            /* Simple debounce */
            for (volatile int d=0; d<500000; d++);
        }

        /* Echo received UART lines */
        if (lineReady) {
            lineReady = 0;
            char line[BUF_SIZE];
            uint8_t i=0;
            while (tail != head) {
                line[i++] = ring[tail];
                tail = (tail + 1) % BUF_SIZE;
            }
            line[i] = '\0';
            char resp[BUF_SIZE + 16];
            snprintf(resp, sizeof(resp), "Echo: %s\r\n", line);
            USART2_SendString(resp);
        }
    }
}
